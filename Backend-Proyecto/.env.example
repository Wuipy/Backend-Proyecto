# SIGASJ Backend — variables de entorno
# ASP.NET Core sobreescribe appsettings con doble guion bajo (__).

# OBLIGATORIO en produccion / Docker
# Copie la cadena desde Supabase -> Project Settings -> Database -> Connection string (Session pooler)
ConnectionStrings__DefaultConnection=Host=aws-1-us-east-1.pooler.supabase.com;Port=5432;Database=postgres;Username=postgres.SU_PROJECT_REF;Password=SU_PASSWORD;SSL Mode=Require;Trust Server Certificate=true

# Formato URI alternativo (tambien valido):
# ConnectionStrings__DefaultConnection=postgresql://postgres.SU_PROJECT_REF:SU_PASSWORD@aws-1-us-east-1.pooler.supabase.com:5432/postgres?sslmode=require

# ERRORES COMUNES:
# - Username=postgres  -> INCORRECTO con pooler; use postgres.SU_PROJECT_REF
# - Password=[YOUR-PASSWORD] -> placeholder sin reemplazar
# - Password con @ # % sin codificar en URI -> codifique o use formato Host=...;Password=...

# Produccion
# Jwt__Secret=generar-clave-segura-minimo-32-caracteres
# Jwt__Issuer=SIGASJ
# Jwt__Audience=SIGASJ-Frontend
# Admin__Usuario=admin
# Admin__Contrasena=contraseña-segura
# Cors__AllowedOrigins__0=https://tu-frontend.com
