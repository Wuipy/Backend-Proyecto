# SIGASJ Backend - Variables de entorno de ejemplo
# Copie este archivo como appsettings.Development.local.json o configure User Secrets en desarrollo.

# ConnectionStrings__DefaultConnection=Data Source=sigasj.db
# Jwt__Secret=SIGASJ-SuperSecretKey-ChangeInProduction-Min32Chars!
# Jwt__Issuer=SIGASJ
# Jwt__Audience=SIGASJ-Frontend
# Jwt__ExpirationHours=8
# Admin__Usuario=admin
# Admin__Contrasena=admin1234
# Cors__AllowedOrigins__0=http://localhost:5173
# Cors__AllowedOrigins__1=http://127.0.0.1:5173

# ASP.NET Core usa appsettings.json por defecto.
# En produccion configure Jwt__Secret con un valor seguro de al menos 32 caracteres.

PORT=5145
DATABASE_URL=Data Source=sigasj.db
JWT_SECRET=SIGASJ-SuperSecretKey-ChangeInProduction-Min32Chars!
NODE_ENV=Development
